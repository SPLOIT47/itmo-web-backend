NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://app:app@localhost:5432/feed

KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=feed-service
KAFKA_CONTENT_TOPIC=content.topic
KAFKA_SOCIAL_TOPIC=social.topic

# Первая подписка consumer group: true = читать топик с начала (иначе Kafka «latest» и старые POST_CREATED не попадут в ленту)
KAFKA_SUBSCRIBE_FROM_BEGINNING=true

# Ограничение размера ленты (1–5000), обязательно в validation
FEED_MAX_SIZE=500

# Бэкфилл постов друга в ленту (GET /posts/user/:id). В Docker Compose (web-full): http://content-service:3000
CONTENT_SERVICE_URL=http://localhost:3003

# Fan-out постов сообщества: owner из Social (если нет feed_sources). В Docker: http://social-service:3000
SOCIAL_SERVICE_URL=http://localhost:3004

# Docker:
# DATABASE_URL=postgresql://app:app@postgres:5432/feed
# KAFKA_BROKERS=kafka:9092
# CONTENT_SERVICE_URL=http://content-service:3000
