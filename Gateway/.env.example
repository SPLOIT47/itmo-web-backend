# --- HTTP ---
NODE_ENV=development
GATEWAY_PORT=4000

# Тот же секрет, что в AuthService (JWT из login/register)
ACCESS_TOKEN_SECRET=change-me

# Общий секрет с AuthService: BFF POST /auth/users/public-batch (подмешивание login в профили)
GATEWAY_SECRET=change-me

# Разрешённые origin для CORS (через запятую). По умолчанию в коде: localhost:5173, localhost:3000
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# --- Upstream (локально или docker-сети) ---
AUTH_SERVICE_URL=http://localhost:3001
PROFILE_SERVICE_URL=http://localhost:3002
CONTENT_SERVICE_URL=http://localhost:3003
SOCIAL_SERVICE_URL=http://localhost:3004
MEDIA_SERVICE_URL=http://localhost:3005
FEED_SERVICE_URL=http://localhost:3006

# Пример для docker-compose (имена сервисов):
# AUTH_SERVICE_URL=http://auth-service:3000
# PROFILE_SERVICE_URL=http://profile-service:3000
# CONTENT_SERVICE_URL=http://content-service:3000
# SOCIAL_SERVICE_URL=http://social-service:3000
# MEDIA_SERVICE_URL=http://media-service:3000
# FEED_SERVICE_URL=http://feed-service:3000
